#define _CRT_SECURE_NO_WARNINGS
#include "function.h"

int main() {
	
	const char* const dat = "studenti.txt";
	int izbor = 0;

	kreirajBazu(dat);

	while (1) {
		printf("1. Dodaj studenta\n");
		printf("2. Ispis svih studenata\n");
		printf("3. Azuriraj prosjek studenta\n");
		printf("4. Obrisi studenta po ID-ju\n");
		printf("5. Sortiraj i ispisi\n");
		printf("6. Pronadji studenta po ID-ju \n");
		printf("7. Izlaz\n");
		printf("Vas izbor: ");

		if (scanf("%d", &izbor) != 1) {
			ocistiBuffer();
			continue;
		}

		if (izbor == 7) break;

		switch (izbor) {
		case 1: dodajNovogStudenta(dat); break;
		case 2: ispisSvihIzDatoteke(dat); break;
		case 3: azurirajProsjekStudenta(dat); break;
		case 4: obrisiStudentaPoID(dat); break;
		case 5: sortirajIOflineIspisi(dat); break;
		case 6: pronadjiStudentaBsearch(dat); break;
		default: printf("Krivi odabir!\n");
		}
	}
	return 0;
}
