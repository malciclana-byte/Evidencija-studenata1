#define _CRT_SECURE_NO_WARNINGS
#include "function.h"

int main() {
	const char* const dat = "studenti.bin";
	int izbor = 0;

	kreirajBazu(dat);

	while (1) {
		printf("1. Dodaj studenta\n");
		printf("2. Ispis svih studenata\n");
		printf("3. Azuriraj prosjek studenta (NOVO - Update)\n");
		printf("4. Obrisi studenta po ID-ju (NOVO - Delete)\n");
		printf("5. Izlaz\n");
		printf("Vas izbor: ");

		if (scanf("%d", &izbor) != 1) {
			ocistiBuffer();
			continue;
		}

		if (izbor == 5) break;

		switch (izbor) {
		case 1: dodajNovogStudenta(dat); break;
		case 2: ispisSvihIzDatoteke(dat); break;
		case 3: azurirajProsjekStudenta(dat); break; 
		case 4: obrisiStudentaPoID(dat); break; 
		default: printf("Krivi odabir!\n");
		}
	}
	return 0;
}
