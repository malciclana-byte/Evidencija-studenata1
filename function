#define _CRT_SECURE_NO_WARNINGS
#include "function.h"

void provjeriAlokaciju(void* p) {
	if (p == NULL) {
		exit(EXIT_FAILURE);
	}
}


void ocistiBuffer() {
	int c;
	while ((c = getchar()) != '\n' && c != EOF);
}


void kreirajBazu(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "a");
	if (fp != NULL) {
		fclose(fp);
	}
}


void dodajNovogStudenta(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "a"); 
	if (fp == NULL) return;

	STUDENT s;
	char tempIme[100], tempPrez[100];

	printf("Unesite ID studenta: ");
	if (scanf("%d", &s.id) != 1) { ocistiBuffer(); fclose(fp); return; }
	ocistiBuffer();

	printf("Ime: "); scanf("%99s", tempIme);
	s.ime = (char*)malloc(strlen(tempIme) + 1);
	provjeriAlokaciju(s.ime);
	strcpy(s.ime, tempIme);

	printf("Prezime: "); scanf("%99s", tempPrez);
	s.prezime = (char*)malloc(strlen(tempPrez) + 1);
	provjeriAlokaciju(s.prezime);
	strcpy(s.prezime, tempPrez);

	printf("Smjer (bez razmaka): "); scanf("%49s", s.smjer);
	printf("Prosjek: "); scanf("%f", &s.prosjek);
	printf("Godina: "); scanf("%d", &s.godina);

	
	fprintf(fp, "%d %s %s %s %.2f %d\n", s.id, s.ime, s.prezime, s.smjer, s.prosjek, s.godina);

	free(s.ime);
	free(s.prezime);
	fclose(fp);
	printf("Student uspjesno dodan!\n");
}

void ispisSvihIzDatoteke(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "r"); 
	if (fp == NULL) return;

	STUDENT s;
	char tempIme[100], tempPrez[100];

	
	while (fscanf(fp, "%d %99s %99s %49s %f %d", &s.id, tempIme, tempPrez, s.smjer, &s.prosjek, &s.godina) == 6) {
		s.ime = (char*)malloc(strlen(tempIme) + 1);
		provjeriAlokaciju(s.ime);
		strcpy(s.ime, tempIme);

		s.prezime = (char*)malloc(strlen(tempPrez) + 1);
		provjeriAlokaciju(s.prezime);
		strcpy(s.prezime, tempPrez);

		printf("ID: %d | Student: %s %s | Smjer: %s | Prosjek: %.2f | %d. god\n",
			s.id, s.ime, s.prezime, s.smjer, s.prosjek, s.godina);

		free(s.ime);
		free(s.prezime);
	}
	fclose(fp);
}


void azurirajProsjekStudenta(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "r");
	if (fp == NULL) return;

	FILE* fpTemp = fopen("temp.txt", "w");
	if (fpTemp == NULL) { fclose(fp); return; }

	int trazeniID, pronadjen = 0;
	float noviProsjek;

	printf("Unesite ID studenta za izmjenu prosjeka: ");
	if (scanf("%d", &trazeniID) != 1) { ocistiBuffer(); fclose(fp); fclose(fpTemp); return; }

	STUDENT s;
	char tempIme[100], tempPrez[100];

	while (fscanf(fp, "%d %99s %99s %49s %f %d", &s.id, tempIme, tempPrez, s.smjer, &s.prosjek, &s.godina) == 6) {
		if (s.id == trazeniID) {
			pronadjen = 1;
			printf("Unesite novi prosjek: ");
			scanf("%f", &noviProsjek);
			s.prosjek = noviProsjek; 
		}
		
		fprintf(fpTemp, "%d %s %s %s %.2f %d\n", s.id, tempIme, tempPrez, s.smjer, s.prosjek, s.godina);
	}

	fclose(fp);
	fclose(fpTemp);

	remove(imeDat);
	rename("temp.txt", imeDat);

	if (pronadjen) printf("Prosjek uspjesno azuriran!\n");
	else printf("Student s ID %d nije pronadjen.\n", trazeniID);
}


void obrisiStudentaPoID(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "r");
	if (fp == NULL) return;

	FILE* fpTemp = fopen("temp.txt", "w");
	if (fpTemp == NULL) { fclose(fp); return; }

	int trazeniID, obrisan = 0;
	printf("Unesite ID studenta kojeg zelite obrisati: ");
	if (scanf("%d", &trazeniID) != 1) { ocistiBuffer(); fclose(fp); fclose(fpTemp); return; }

	STUDENT s;
	char tempIme[100], tempPrez[100];

	while (fscanf(fp, "%d %99s %99s %49s %f %d", &s.id, tempIme, tempPrez, s.smjer, &s.prosjek, &s.godina) == 6) {
		
		if (s.id != trazeniID) {
			fprintf(fpTemp, "%d %s %s %s %.2f %d\n", s.id, tempIme, tempPrez, s.smjer, s.prosjek, s.godina);
		}
		else {
			obrisan = 1;
		}
	}

	fclose(fp);
	fclose(fpTemp);

	remove(imeDat);
	rename("temp.txt", imeDat);

	if (obrisan) printf("Student uspjesno obrisan!\n");
	else printf("Student s tim ID-jem ne postoji.\n");
}


int usporediStudentePoID(const void* a, const void* b) {
	const STUDENT* s1 = (const STUDENT*)a;
	const STUDENT* s2 = (const STUDENT*)b;

	if (s1->id < s2->id) return -1;
	if (s1->id > s2->id) return 1;
	return 0;
}


void sortirajIOflineIspisi(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "r");
	if (fp == NULL) return;

	int brojStudenata = 0;
	STUDENT s;
	char tempIme[100], tempPrez[100];

	while (fscanf(fp, "%d %99s %99s %49s %f %d", &s.id, tempIme, tempPrez, s.smjer, &s.prosjek, &s.godina) == 6) {
		brojStudenata++;
	}

	if (brojStudenata == 0) {
		printf("Baza podataka je prazna.\n");
		fclose(fp);
		return;
	}

	rewind(fp); 
	STUDENT* polje = (STUDENT*)malloc(brojStudenata * sizeof(STUDENT));
	provjeriAlokaciju(polje);

	for (int i = 0; i < brojStudenata; i++) {
		fscanf(fp, "%d %99s %99s %49s %f %d", &polje[i].id, tempIme, tempPrez, polje[i].smjer, &polje[i].prosjek, &polje[i].godina);

		polje[i].ime = (char*)malloc(strlen(tempIme) + 1);
		provjeriAlokaciju(polje[i].ime);
		strcpy(polje[i].ime, tempIme);

		polje[i].prezime = (char*)malloc(strlen(tempPrez) + 1);
		provjeriAlokaciju(polje[i].prezime);
		strcpy(polje[i].prezime, tempPrez);
	}
	fclose(fp);

	
	qsort(polje, brojStudenata, sizeof(STUDENT), usporediStudentePoID);

	printf("\n--- SORTIRANI ISPIS STUDENATA (PO ID-ju) ---\n");
	for (int i = 0; i < brojStudenata; i++) {
		printf("ID: %d | %s %s | Smjer: %s | Prosjek: %.2f | %d.god\n",
			polje[i].id, polje[i].ime, polje[i].prezime, polje[i].smjer, polje[i].prosjek, polje[i].godina);
		free(polje[i].ime);
		free(polje[i].prezime);
	}
	free(polje);
}

void pronadjiStudentaBsearch(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "r");
	if (fp == NULL) return;

	int brojStudenata = 0;
	STUDENT s;
	char tempIme[100], tempPrez[100];

	while (fscanf(fp, "%d %99s %99s %49s %f %d", &s.id, tempIme, tempPrez, s.smjer, &s.prosjek, &s.godina) == 6) {
		brojStudenata++;
	}

	if (brojStudenata == 0) {
		printf("Baza je prazna.\n");
		fclose(fp);
		return;
	}

	rewind(fp);
	STUDENT* polje = (STUDENT*)malloc(brojStudenata * sizeof(STUDENT));
	provjeriAlokaciju(polje);

	for (int i = 0; i < brojStudenata; i++) {
		fscanf(fp, "%d %99s %99s %49s %f %d", &polje[i].id, tempIme, tempPrez, polje[i].smjer, &polje[i].prosjek, &polje[i].godina);

		polje[i].ime = (char*)malloc(strlen(tempIme) + 1);
		provjeriAlokaciju(polje[i].ime);
		strcpy(polje[i].ime, tempIme);

		polje[i].prezime = (char*)malloc(strlen(tempPrez) + 1);
		provjeriAlokaciju(polje[i].prezime);
		strcpy(polje[i].prezime, tempPrez);
	}
	fclose(fp);

	
	qsort(polje, brojStudenata, sizeof(STUDENT), usporediStudentePoID);

	STUDENT kljuc;
	printf("Unesite ID studenta kojeg trazite: ");
	if (scanf("%d", &kljuc.id) != 1) {
		ocistiBuffer();
		for (int i = 0; i < brojStudenata; i++) { free(polje[i].ime); free(polje[i].prezime); }
		free(polje); return;
	}

	
	STUDENT* pronadjen = (STUDENT*)bsearch(&kljuc, polje, brojStudenata, sizeof(STUDENT), usporediStudentePoID);

	if (pronadjen != NULL) {
		printf("\n[STUDENT PRONADJEN U BSEARCH]\n");
		printf("ID: %d | %s %s | Smjer: %s | Prosjek: %.2f | %d.god\n",
			pronadjen->id, pronadjen->ime, pronadjen->prezime, pronadjen->smjer, pronadjen->prosjek, pronadjen->godina);
	}
	else {
		printf("Student s ID-jem %d ne postoji u bazi.\n", kljuc.id);
	}

	for (int i = 0; i < brojStudenata; i++) {
		free(polje[i].ime);
		free(polje[i].prezime);
	}
	free(polje);
}
