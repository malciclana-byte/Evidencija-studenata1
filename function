#define _CRT_SECURE_NO_WARNINGS
#include "function.h" 
// prekida program ako alokacija memorije ne uspije
void provjeriAlokaciju(void* p) {
	if (p == NULL) {
		exit(EXIT_FAILURE); 
	}
}
 //brise zaostale entere iz spremnika nakon unosa brojeva
void ocistiBuffer() {
	int c;
	while ((c = getchar()) != '\n' && c != EOF);
}
//stvara praznu datoteku ako vec ne postoji
void kreirajBazu(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "ab"); 
	if (fp != NULL) {
		fclose(fp); 
	}
}
//unos novog studenta s dinamickim imenom/prezimenom na kraj
void dodajNovogStudenta(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "ab"); 
	if (fp == NULL) return;

	STUDENT s;
	char tempIme[100], tempPrez[100];

	printf("Unesite ID studenta: ");
	if (scanf("%d", &s.id) != 1) { ocistiBuffer(); fclose(fp); return; }
	ocistiBuffer();

	printf("Ime: ");
	scanf("%99s", tempIme);

	
	s.ime = (char*)malloc(strlen(tempIme) + 1);
	provjeriAlokaciju(s.ime); 
	strcpy(s.ime, tempIme);

	printf("Prezime: ");
	scanf("%99s", tempPrez);
	
	s.prezime = (char*)malloc(strlen(tempPrez) + 1);
	provjeriAlokaciju(s.prezime);
	strcpy(s.prezime, tempPrez);

	printf("Smjer: "); scanf("%49s", s.smjer);
	printf("Prosjek: "); scanf("%f", &s.prosjek);
	printf("Godina: "); scanf("%d", &s.godina);


	int iLen = (int)strlen(s.ime) + 1;
	int pLen = (int)strlen(s.prezime) + 1;

	//binarni upis svih podataka u datoteku
	fwrite(&s.id, sizeof(int), 1, fp);
	fwrite(&iLen, sizeof(int), 1, fp); 
	fwrite(s.ime, sizeof(char), iLen, fp); 
	fwrite(&pLen, sizeof(int), 1, fp); 
	fwrite(s.prezime, sizeof(char), pLen, fp); 
	fwrite(&s.prosjek, sizeof(float), 1, fp);
	fwrite(&s.godina, sizeof(int), 1, fp);
	fwrite(s.smjer, sizeof(char), 50, fp);

	
	free(s.ime);
	free(s.prezime);
	fclose(fp); 
}

 //cita i ispisuje sve studente iz binarne datoteke 
void ispisSvihIzDatoteke(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "rb"); 
	if (fp == NULL) return;

	STUDENT s;
	int iLen, pLen;

	
	while (fread(&s.id, sizeof(int), 1, fp) == 1) {
		//Prvo citamo duljinu stringa, alociramo prostor, pa citamo
		fread(&iLen, sizeof(int), 1, fp);
		s.ime = (char*)malloc(iLen);
		provjeriAlokaciju(s.ime);
		fread(s.ime, sizeof(char), iLen, fp);

		
		fread(&pLen, sizeof(int), 1, fp);
		s.prezime = (char*)malloc(pLen);
		provjeriAlokaciju(s.prezime);
		fread(s.prezime, sizeof(char), pLen, fp);

		fread(&s.prosjek, sizeof(float), 1, fp);
		fread(&s.godina, sizeof(int), 1, fp);
		fread(s.smjer, sizeof(char), 50, fp);

		printf("ID: %d | Student: %s %s | Smjer: %s | Prosjek: %.2f | %d. god\n",
			s.id, s.ime, s.prezime, s.smjer, s.prosjek, s.godina);

		
		free(s.ime);
		free(s.prezime);
	}
	fclose(fp);
}

 // Pronalazi studenta po ID-u i mijenja mu prosjek izravno u datoteci
void azurirajProsjekStudenta(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "rb+"); 
	if (fp == NULL) {
		printf("Pogreska pri otvaranju datoteke!\n");
		return;
	}

	int trazeniID;
	float noviProsjek;
	int pronadjen = 0;

	printf("Unesite ID studenta za izmjenu prosjeka: ");
	if (scanf("%d", &trazeniID) != 1) { ocistiBuffer(); fclose(fp); return; }

	int id, iLen, pLen;
	long pozicijaID;  

	 
	while (fread(&id, sizeof(int), 1, fp) == 1) {
		
		pozicijaID = ftell(fp) - sizeof(int);

		fread(&iLen, sizeof(int), 1, fp);
		fseek(fp, iLen, SEEK_CUR); 

		fread(&pLen, sizeof(int), 1, fp);
		fseek(fp, pLen, SEEK_CUR); 

		if (id == trazeniID) {
			pronadjen = 1;
			printf("Unesite novi prosjek: ");
			scanf("%f", &noviProsjek);
			
			fseek(fp, pozicijaID + sizeof(int) + sizeof(int) + iLen + sizeof(int) + pLen, SEEK_SET);

			fwrite(&noviProsjek, sizeof(float), 1, fp); 
			printf("Prosjek uspjesno azuriran!\n");
			break;
		}

		
		fseek(fp, sizeof(float) + sizeof(int) + 50, SEEK_CUR);
	}

	if (!pronadjen) printf("Student s ID %d nije pronadjen.\n", trazeniID);
	fclose(fp);
}

// brise studenta tako da sve ostale zapise kopira u temp datoteku, pa zamijeni mjesta 
void obrisiStudentaPoID(const char* const imeDat) {
	FILE* fp = fopen(imeDat, "rb"); 
	if (fp == NULL) return;

	FILE* fpTemp = fopen("temp.bin", "wb"); 
	if (fpTemp == NULL) { fclose(fp); return; }

	int trazeniID;
	int obrisan = 0;
	printf("Unesite ID studenta kojeg zelite obrisati: ");
	if (scanf("%d", &trazeniID) != 1) { ocistiBuffer(); fclose(fp); fclose(fpTemp); return; }

	STUDENT s;
	int iLen, pLen;

	while (fread(&s.id, sizeof(int), 1, fp) == 1) {
		fread(&iLen, sizeof(int), 1, fp);
		s.ime = (char*)malloc(iLen);
		provjeriAlokaciju(s.ime);
		fread(s.ime, sizeof(char), iLen, fp);

		fread(&pLen, sizeof(int), 1, fp);
		s.prezime = (char*)malloc(pLen);
		provjeriAlokaciju(s.prezime);
		fread(s.prezime, sizeof(char), pLen, fp);

		fread(&s.prosjek, sizeof(float), 1, fp);
		fread(&s.godina, sizeof(int), 1, fp);
		fread(s.smjer, sizeof(char), 50, fp);

		 
		if (s.id != trazeniID) {
			fwrite(&s.id, sizeof(int), 1, fpTemp);
			fwrite(&iLen, sizeof(int), 1, fpTemp);
			fwrite(s.ime, sizeof(char), iLen, fpTemp);
			fwrite(&pLen, sizeof(int), 1, fpTemp);
			fwrite(s.prezime, sizeof(char), pLen, fpTemp);
			fwrite(&s.prosjek, sizeof(float), 1, fpTemp);
			fwrite(&s.godina, sizeof(int), 1, fpTemp);
			fwrite(s.smjer, sizeof(char), 50, fpTemp);
		}
		else {
			obrisan = 1; 
		}

		free(s.ime);
		free(s.prezime);
	}

	fclose(fp);
	fclose(fpTemp);

	
	remove(imeDat); 
		rename("temp.bin", imeDat);

		if (obrisan) printf("Student uspjesno obrisan!\n");
		else printf("Student s tim ID-jem ne postoji.\n");
}
